(advice-add 'org-notify-make-todo :override
            (lambda (todo)
              \"Permite que org-notify procese tareas sin TODO y use tanto SCHEDULED como DEADLINE.\"
              (let* ((heading   (org-get-heading t t t t))
                     (deadline  (org-get-deadline-time (point)))
                     (scheduled (org-get-scheduled-time (point)))
                     ;; Usamos cualquier timestamp válido disponible para activar la notificación
                     (time      (or deadline scheduled)))
                (when time
                  (list :heading heading
                        :deadline deadline
                        :scheduled scheduled
                        :time time
                        :file (buffer-file-name)
                        :marker (point-marker))))))

