    (interactive)
    (let* ((contents (if (use-region-p)
                         (buffer-substring-no-properties
                          (region-beginning)
                          (region-end))
                       (buffer-string)))
           (temp-file (make-temp-file \"transfer\" nil \".txt\" contents))
           (name (file-name-nondirectory temp-file)))
      (message \"Sending %s to transfer.sh...\" temp-file)
      (let ((url (string-trim-right
                  (shell-command-to-string
                   (format \"curl --silent --upload-file %s https://transfer.sh/%s\"
