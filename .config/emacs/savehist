" 0 1 (yank-handler (evil-yank-line-handler nil t) fontified t)) ";;; jp-emacs-treesit.el
;; Tree-sitter configuration

(jp-emacs-configure

 ;; ----------------------------
 ;; TREE-SITTER LANGUAGE SOURCES
 ;; ----------------------------

 (setq treesit-language-source-alist
       '((bash \"https://github.com/tree-sitter/tree-sitter-bash\")
         (css \"https://github.com/tree-sitter/tree-sitter-css\")
         (dockerfile \"https://github.com/camdencheek/tree-sitter-dockerfile\" \"main\" \"src\")
         (go \"https://github.com/tree-sitter/tree-sitter-go\")
         (html \"https://github.com/tree-sitter/tree-sitter-html\")
         (javascript \"https://github.com/tree-sitter/tree-sitter-javascript\" \"master\" \"src\")
         (jsdoc \"https://github.com/tree-sitter/tree-sitter-jsdoc\")
         (json \"https://github.com/tree-sitter/tree-sitter-json\")
         (markdown \"https://github.com/tree-sitter-grammars/tree-sitter-markdown\" \"split_parser\" \"tree-sitter-markdown/src\")
         (markdown-inline \"https://github.com/tree-sitter-grammars/tree-sitter-markdown\" \"split_parser\" \"tree-sitter-markdown-inline/src\")
         (python \"https://github.com/tree-sitter/tree-sitter-python\")
         (ruby \"https://github.com/tree-sitter/tree-sitter-ruby\")
         (rust \"https://github.com/tree-sitter/tree-sitter-rust\")
         (toml \"https://github.com/ikatyang/tree-sitter-toml\")
         (tsx \"https://github.com/tree-sitter/tree-sitter-typescript\" \"master\" \"tsx/src\")
         (typescript \"https://github.com/tree-sitter/tree-sitter-typescript\" \"master\" \"typescript/src\")
         (yaml \"https://github.com/tree-sitter-grammars/tree-sitter-yaml\")))

 ;; ----------------------------
 ;; AUTO INSTALL GRAMMARS
 ;; ----------------------------

 (defun jp/treesit-install-if-missing ()
   \"Automatically install Tree-sitter grammar if missing.\"
   (when (and (fboundp 'treesit-install-language-grammar)
              (treesit-language-available-p major-mode)
              (not (treesit-ready-p major-mode)))
     (let ((lang (intern (string-remove-suffix \"-ts-mode\"
                                               (symbol-name major-mode)))))
       (when (assoc lang treesit-language-source-alist)
         (treesit-install-language-grammar lang)))))

 (add-hook 'prog-mode-hook #'jp/treesit-install-if-missing)

 ;; ----------------------------
 ;; MODE REMAPPING
 ;; ----------------------------

 (setq major-mode-remap-alist
       '((python-mode . python-ts-mode)
         (css-mode . css-ts-mode)
         (js-mode . js-ts-mode)
         (js2-mode . js-ts-mode)
         (typescript-mode . typescript-ts-mode)
         (json-mode . json-ts-mode)
         (ruby-mode . ruby-ts-mode)
         (yaml-mode . yaml-ts-mode)
         (bash-mode . bash-ts-mode)))

 ;; ----------------------------
 ;; PYTHON
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.py\\\\'\" . python-ts-mode))

 (add-hook 'python-ts-mode-hook
           (lambda ()
             (setq indent-tabs-mode nil)
             (setq python-indent-offset 4)))

 ;; ----------------------------
 ;; JAVASCRIPT
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.jsx?\\\\'\" . js-ts-mode))

 (setq js-indent-level 2)

 (add-hook 'js-ts-mode-hook
           (lambda ()
             (setq indent-tabs-mode nil)))

 ;; ----------------------------
 ;; TYPESCRIPT / TSX
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.ts\\\\'\" . typescript-ts-mode))
 (add-to-list 'auto-mode-alist '(\"\\\\.tsx\\\\'\" . tsx-ts-mode))

 (setq typescript-indent-level 2)

 (add-hook 'typescript-ts-mode-hook
           (lambda ()
             (setq indent-tabs-mode nil)))

 (add-hook 'tsx-ts-mode-hook
           (lambda ()
             (setq indent-tabs-mode nil)))

 ;; ----------------------------
 ;; RUBY
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.rb\\\\'\" . ruby-ts-mode))
 (add-to-list 'auto-mode-alist '(\"Rakefile\\\\'\" . ruby-ts-mode))
 (add-to-list 'auto-mode-alist '(\"Gemfile\\\\'\" . ruby-ts-mode))

 (setq ruby-indent-level 2
       ruby-indent-tabs-mode nil)

 ;; ----------------------------
 ;; GO
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.go\\\\'\" . go-ts-mode))

 (add-hook 'go-ts-mode-hook
           (lambda ()
             (setq indent-tabs-mode t)
             (setq tab-width 4)
             (setq-local go-ts-mode-indent-offset tab-width)))

 ;; ----------------------------
 ;; RUST
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.rs\\\\'\" . rust-ts-mode))

 (setq rust-indent-level 2)

 ;; ----------------------------
 ;; YAML
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.ya?ml\\\\'\" . yaml-ts-mode))

 ;; ----------------------------
 ;; MARKDOWN
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.md\\\\'\" . markdown-ts-mode))

 ;; ----------------------------
 ;; TOML
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"\\\\.toml\\\\'\" . toml-ts-mode))

 ;; ----------------------------
 ;; DOCKERFILE
 ;; ----------------------------

 (add-to-list 'auto-mode-alist '(\"Dockerfile.*\\\\'\" . dockerfile-ts-mode))

 )"))
