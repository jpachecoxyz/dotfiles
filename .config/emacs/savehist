    (interactive)
    (unless (display-graphic-p frame)
      (add-hook 'window-setup-hook 'emacs-solo/clear-terminal-background-color)
      (add-hook 'ef-themes-post-load-hook 'emacs-solo/clear-terminal-background-color))

