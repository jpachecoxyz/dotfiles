;; =============================================================================

(defun my/org-notify-telegram-action-with-chat (notif-plist)
  \"Extrae las propiedades de la nota de Org y envía un mensaje formateado por Telega.\"
  (let* ((heading  (or (plist-get notif-plist :heading) \"Tarea pendiente\"))
         (deadline (plist-get notif-plist :deadline))
         (sched    (plist-get notif-plist :scheduled))
         (file     (file-name-nondirectory
                    (or (plist-get notif-plist :file) \"agenda.org\")))
         (marker   (plist-get notif-plist :marker))
         ;; API nativa de Org: extrae el ID apuntando al marcador (salta comentarios)
         (chat-id-str (when marker (org-entry-get marker \"TELEGRAM_ID\")))
         (chat-id (when chat-id-str (string-to-number chat-id-str)))
         ;; Diseño del cuerpo del mensaje en Markdown de Telegram
         (msg (concat
               \"📅 *Recordatorio de Agenda*\\n\\n\"
               (format \"• *Evento/Tarea:* %s\\n\" heading)
               (when deadline
                 (format \"• *Fecha límite:* %s\\n\"
                         (format-time-string \"%d/%m %H:%M\" deadline)))
               (when sched
                 (format \"• *Programada:* %s\\n\"
                         (format-time-string \"%d/%m %H:%M\" sched)))
               (format \"• *Archivo:* %s\" file))))
    
    (message \"[tg] Intentando enviar... chat-id=%s heading=%s\" chat-id heading)
    
    ;; Verificaciones de seguridad antes de invocar la API de Telega
    (when (and chat-id (featurep 'telega) (telega-server-live-p))
      (run-at-time 0 nil
                   `(lambda ()
                      (condition-case err
                          (progn
                            (telega--sendMessage
                             (telega-chat-get ,chat-id)
                             (list :@type \"inputMessageText\"
                                   :text (telega-string-fmt-text ,msg))
                             nil nil)
                            (message \"[tg] ¡Mensaje enviado con éxito!\"))
                        (error
                         (message \"[tg] ERROR al enviar por Telega: %s\"
                                  (error-message-string err)))))))))


