(advice-add 'org-notify-make-todo :override
            (lambda (&rest _)
              \"Parche universal: permite procesar elementos sin palabra clave TODO
y extrae tanto SCHEDULED como DEADLINE de forma segura.\"
              (let* ((heading   (org-get-heading t t t t))
                     (deadline  (org-get-deadline-time (point)))
                     (scheduled (org-get-scheduled-time (point)))
                     ;; Registra la notificación usando la primera fecha que encuentre disponible
                     (time      (or deadline scheduled)))
                (when time
                  (list :heading heading
                        :deadline deadline
                        :scheduled scheduled
                        :time time
                        :file (buffer-file-name)
                        :marker (point-marker))))))

(defun my/org-notify-update-patched ()
  \"Escáner personalizado que busca cualquier marca de tiempo activa (Deadline o Scheduled)
ignorando si tiene o no un estado TODO.\"
  (let ((org-todo-keywords-for-agenda '(\"\"))) ;; Engaña al motor para leer todos los encabezados
    (setq org-notify-todo-list nil)
    (org-map-entries
     (lambda ()
       (let ((todo (org-notify-make-todo)))
         (when todo
           (push todo org-notify-todo-list))))
     ;; Mapea todo lo que tenga marcas de tiempo activas hacia el futuro
     \"+TIMESTAMP>=\\\"<now>\\\"|+DEADLINE>=\\\"<now>\\\"|+SCHEDULED>=\\\"<now>\\\"\"
     'agenda)))

;; Reemplazamos el método de actualización por nuestra versión sin restricciones
(advice-add 'org-notify-update :override #'my/org-notify-update-patched)


