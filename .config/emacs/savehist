          '((\"[ \\t]\\\\([+-][^ \\t\\n]+\\\\)\" 1 font-lock-builtin-face)
            (\"^[^ \\t\\n]+:.*\" . font-lock-string-face)
            (\"^\\\\[[1-9][0-9]*\\\\]\" . font-lock-constant-face)))))

;;; Show battery status on the mode line with `display-battery-mode'
