;;;; Search
(jp-emacs-configure
  (setq notmuch-search-oldest-first nil)
  (setq notmuch-search-result-format
        '((\"date\" . \"%12s  \")
          (\"count\" . \"%-7s  \")
          (\"authors\" . \"%-20s  \")
          (\"subject\" . \"%-80s  \")
