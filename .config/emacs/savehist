  (defun jp/upload-text ()
    \"Upload region or buffer contents to the active file sharing service.\"
    (interactive)
    (let* ((contents (if (use-region-p)
                         (buffer-substring-no-properties
                          (region-beginning)
                          (region-end))
                       (buffer-string)))
