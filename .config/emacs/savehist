  (setq Man-notify-method 'pushy)) ; does not obey `display-buffer-alist'

;;;; `proced' (process monitor, similar to `top')
(jp-emacs-configure
  (setq proced-auto-update-flag 'visible) ; Emacs 30 supports more the `visible' value
