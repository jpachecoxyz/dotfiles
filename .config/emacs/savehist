 ;; ----------------------------
 ;; AUTO INSTALL GRAMMARS
 ;; ----------------------------

 (defun jp/treesit-install-if-missing ()
   (interactive)
   \"Automatically install Tree-sitter grammar if missing.\"
   (when (and (fboundp 'treesit-install-language-grammar)
              (treesit-language-available-p major-mode)
              (not (treesit-ready-p major-mode)))
     (let ((lang (intern (string-remove-suffix \"-ts-mode\"
                                               (symbol-name major-mode)))))
       (when (assoc lang treesit-language-source-alist)
         (treesit-install-language-grammar lang)))))

 (add-hook 'prog-mode-hook #'jp/treesit-install-if-missing)

