#!/usr/bin/env bash

qemu-system-x86_64 --enable-kvm -m 8G -smp 8 -cpu host -M q35 \
  -drive file=/home/javier/vm/robotics/robotics.qcow2,media=disk,cache=unsafe \
  -full-screen -vga virtio \
  -audiodev pipewire,id=audiodev1 -device intel-hda -device hda-duplex,audiodev=audiodev1 \
  -rtc base=localtime \
  -device qemu-xhci,id=usb-bus \
  -device usb-host,bus=usb-bus.0,vendorid=0x1f75,productid=0x0917 \
  -net nic -net bridge,br=br0 \
  -netdev user,id=net0 -device e1000,netdev=net0
