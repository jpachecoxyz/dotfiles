#!/usr/bin/env bash

# Script para crear Puente + TAP para Virtualización Industrial
# Requiere: iproute2 y fzf

if ! command -v fzf &>/dev/null; then
    echo "❌ fzf no está instalado."
    exit 1
fi

echo "🔎 Buscando interfaces físicas..."
iface=$(ip -o link show | awk -F': ' '{print $2}' \
    | grep -v -E "lo|br-|docker|veth|virbr|tap" \
    | fzf --prompt="Selecciona la interfaz física (Ethernet): ")

if [ -z "$iface" ]; then exit 1; fi

read -rp "📛 Nombre del puente (br0): " brname
brname=${brname:-br0}

read -rp "🌐 IP estática para el puente (ej. 192.168.0.10/24): " ipaddr
if [ -z "$ipaddr" ]; then echo "❌ Necesitas una IP para el PLC"; exit 1; fi

echo "⚙️ Configurando Bridge y TAP..."

# Comandos de ejecución
sudo ip link add name "$brname" type bridge
sudo ip link set dev "$brname" up

# Limpiar IP de la interfaz física y subirla al puente
sudo ip addr flush dev "$iface"
sudo ip link set dev "$iface" master "$brname"
sudo ip link set dev "$iface" up

# Asignar IP al puente (Esta será la IP de tu Linux)
sudo ip addr add "$ipaddr" dev "$brname"

# CREAR TAP PARA QEMU
# Esto permite que la VM se conecte al puente
sudo ip tuntap add dev tap0 mode tap user $USER
sudo ip link set tap0 master "$brname"
sudo ip link set tap0 up

echo "✅ ¡Configuración lista!"
echo "----------------------------------------"
echo "🖥️  Host Linux (Bridge $brname): $ipaddr"
echo "🔌 Interfaz Física: $iface"
echo "🤖 Interfaz para QEMU: tap0"
echo "----------------------------------------"
echo "👉 En tu comando QEMU añade:"
echo "   -netdev tap,id=n1,ifname=tap0,script=no,downscript=no -device virtio-net-pci,netdev=n1"
